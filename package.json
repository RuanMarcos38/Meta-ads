{
  "name": "gestao-ads-r2r",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm --workspace apps/api run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/api run build && npm --workspace apps/web run build",
    "start": "npm --workspace apps/api run start",
    "typecheck": "npm --workspace apps/api run typecheck && npm --workspace apps/web run typecheck",
    "test": "npm --workspace apps/api run test",
    "seed": "npm --workspace apps/api run seed",
    "prisma:generate": "npm --workspace apps/api run prisma:generate",
    "prisma:migrate": "npm --workspace apps/api run prisma:migrate"
  }
}
