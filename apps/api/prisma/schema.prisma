generator client { provider = "prisma-client-js" }
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role { SUPER_ADMIN AGENCY_ADMIN MANAGER CLIENT }
enum InsightLevel { account campaign adset ad }

model Organization {
  id        String   @id @default(uuid())
  name      String
  document  String?
  email     String?
  phone     String?
  users     User[]
  clients   Client[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           Role     @default(CLIENT)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  clientId       String?
  client         Client?  @relation(fields: [clientId], references: [id])
  isActive       Boolean  @default(true)
  mustChangePassword Boolean @default(false)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Client {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  companyName    String?
  document       String?
  email          String?
  phone          String?
  segment        String?
  status         String   @default("active")
  notes          String?
  primaryResultAction String?
  users          User[]
  adAccounts     MetaAdAccount[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MetaConnection {
  id                   String   @id @default(uuid())
  organizationId       String
  clientId             String?
  metaUserId           String?
  accessTokenEncrypted String
  tokenExpiresAt       DateTime?
  scopes               String?
  status               String   @default("active")
  adAccounts           MetaAdAccount[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model MetaAdAccount {
  id             String   @id @default(uuid())
  organizationId String
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  connectionId   String
  connection     MetaConnection @relation(fields: [connectionId], references: [id])
  accountId      String
  name           String?
  currency       String?
  timezone       String?
  accountStatus  Int?
  isActive       Boolean  @default(true)
  campaigns      Campaign[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Campaign {
  id              String   @id @default(uuid())
  organizationId  String
  clientId        String
  adAccountId     String
  adAccount       MetaAdAccount @relation(fields: [adAccountId], references: [id])
  metaCampaignId  String
  name            String
  objective       String?
  status          String?
  effectiveStatus String?
  buyingType      String?
  dailyBudget     Decimal?
  lifetimeBudget  Decimal?
  startTime       DateTime?
  stopTime        DateTime?
  adSets          AdSet[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@unique([adAccountId, metaCampaignId])
}

model AdSet {
  id               String  @id @default(uuid())
  campaignId       String
  campaign         Campaign @relation(fields: [campaignId], references: [id])
  metaAdsetId      String
  name             String
  status           String?
  effectiveStatus  String?
  dailyBudget      Decimal?
  lifetimeBudget   Decimal?
  optimizationGoal String?
  billingEvent     String?
  ads              Ad[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@unique([campaignId, metaAdsetId])
}

model Ad {
  id              String @id @default(uuid())
  adSetId         String
  adSet           AdSet  @relation(fields: [adSetId], references: [id])
  campaignId      String
  metaAdId        String
  name            String
  status          String?
  effectiveStatus String?
  creativeId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@unique([adSetId, metaAdId])
}

model InsightDaily {
  id             String   @id @default(uuid())
  organizationId String
  clientId       String
  adAccountId    String
  campaignId     String?
  adSetId        String?
  adId           String?
  level          InsightLevel
  date           DateTime
  spend          Decimal  @default(0)
  impressions    Int      @default(0)
  reach          Int      @default(0)
  frequency      Decimal  @default(0)
  clicks         Int      @default(0)
  inlineLinkClicks Int    @default(0)
  ctr            Decimal  @default(0)
  cpc            Decimal  @default(0)
  cpm            Decimal  @default(0)
  leads          Int      @default(0)
  conversations  Int      @default(0)
  purchases      Int      @default(0)
  revenue        Decimal  @default(0)
  costPerLead    Decimal  @default(0)
  costPerConversation Decimal @default(0)
  rawActionsJson       Json?
  rawCostPerActionJson Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@unique([level, date, adAccountId, campaignId, adSetId, adId])
  @@index([clientId, date])
}

model SyncJob {
  id              String    @id @default(uuid())
  organizationId  String
  clientId        String?
  adAccountId     String?
  type            String
  status          String    @default("running")
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  errorMessage    String?
  recordsProcessed Int      @default(0)
  createdBy       String?
}

model Report {
  id             String   @id @default(uuid())
  organizationId String
  clientId       String
  title          String
  periodStart    DateTime
  periodEnd      DateTime
  fileUrl        String?
  summaryText    String?
  createdBy      String?
  createdAt      DateTime @default(now())
}

model Alert {
  id             String   @id @default(uuid())
  organizationId String
  clientId       String?
  type           String
  severity       String   @default("info")
  title          String
  message        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?
  userId         String?
  action         String
  entity         String?
  entityId       String?
  ip             String?
  userAgent      String?
  metadataJson   Json?
  createdAt      DateTime @default(now())
}
