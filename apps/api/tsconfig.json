{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/server.ts",
    "src/routes.ts",
    "src/config/**/*.ts",
    "src/shared/**/*.ts",
    "src/modules/meta/**/*.ts",
    "src/modules/demo/**/*.ts"
  ]
}
