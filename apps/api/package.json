{
  "name": "@gestao-ads/api",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx src/tests/smoke.ts",
    "prisma:generate": "prisma generate",
    "migrate": "prisma migrate deploy || prisma db push",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.6.0",
    "pdfkit": "^0.15.1",
    "prisma": "^5.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.8.7",
    "@types/pdfkit": "^0.13.8",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
