NODE_ENV=production
PORT=3333

# Supabase: projeto CRM R2 MARKETING DIGITAL.
# Substitua <SENHA_DO_BANCO> e mantenha obrigatoriamente o schema gestao_ads.
# Caracteres especiais da senha precisam estar codificados para URL.
DATABASE_URL=postgresql://postgres:<SENHA_DO_BANCO>@db.iqrnytsgwaiegddfxfjs.supabase.co:5432/postgres?sslmode=require&schema=gestao_ads
DIRECT_URL=postgresql://postgres:<SENHA_DO_BANCO>@db.iqrnytsgwaiegddfxfjs.supabase.co:5432/postgres?sslmode=require&schema=gestao_ads
DATABASE_SCHEMA=gestao_ads
PRISMA_DB_PUSH=true

# Ative somente no primeiro deploy para criar/atualizar o administrador.
RUN_SEED_ON_START=false
SEED_ADMIN_NAME=Administrador R2R
SEED_ADMIN_EMAIL=admin@r2rmarketingdigital.com.br
SEED_ADMIN_PASSWORD=
SEED_DEMO_CLIENT=false

# Gere chaves diferentes e fortes. Nunca reutilize secrets de outros projetos.
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d
# 64 caracteres hexadecimais: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

FRONTEND_URL=https://gestao.r2rmarketingdigital.com.br
API_PUBLIC_URL=https://api-gestao.r2rmarketingdigital.com.br
CORS_ORIGINS=https://gestao.r2rmarketingdigital.com.br

DEMO_MODE=false
SYNC_INTERVAL_MINUTES=60
LOG_LEVEL=info

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://api-gestao.r2rmarketingdigital.com.br/meta/oauth/callback
META_API_VERSION=v21.0

REDIS_URL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
WHATSAPP_SUPPORT=5547996753735
